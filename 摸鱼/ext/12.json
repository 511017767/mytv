    const PLAY_KEY = '__play__';
    try {
      let playHistory = (window.store && store.get(PLAY_KEY)) || [];
      let lisBtn = document.getElementsByClassName('listen-btn')[0];
      if (playHistory.length) {
        lisBtn.style.display = 'block';
        lisBtn.href = playHistory[0].playurl;
        lisBtn.innerText = '上次收听到：' + playHistory[0].book_title + ' ' + playHistory[0].chapterTitle;
      } else {
        lisBtn.style.display = 'none';
      }
    } catch(e) {}

    // 简易 cookie（保持你原逻辑）
    jQuery.cookie = function(name, value, options) {
      if (typeof value != 'undefined') {
        options = options || {};
        if (value === null) { value = ''; options.expires = -1; }
        var expires = '';
        if (options.expires && (typeof options.expires == 'number' || options.expires.toUTCString)) {
          var date;
          if (typeof options.expires == 'number') {
            date = new Date();
            var totalTime = 24 * 3600;
            var hour = date.getHours();
            var minutes = date.getMinutes();
            var seconds = date.getSeconds();
            var pastTime = 3600 * hour + 60 * minutes + seconds;
            var leftTime = totalTime - pastTime;
            date.setTime(date.getTime() + (options.expires * leftTime * 1000));
          } else { date = options.expires; }
          expires = '; expires=' + date.toUTCString();
        }
        var path = options.path ? '; path=' + (options.path) : '';
        var domain = options.domain ? '; domain=' + (options.domain) : '';
        var secure = options.secure ? '; secure' : '';
        document.cookie = [name, '=', encodeURIComponent(value), expires, path, domain, secure].join('');
      } else {
        var cookieValue = null;
        if (document.cookie && document.cookie != '') {
          var cookies = document.cookie.split(';');
          for (var i = 0; i < cookies.length; i++) {
            var cookie = jQuery.trim(cookies[i]);
            if (cookie.substring(0, name.length + 1) == (name + '=')) {
              cookieValue = decodeURIComponent(cookie.substring(name.length + 1));
              break;
            }
          }
        }
        return cookieValue;
      }
    };

    // 弹窗展示/关闭
    (function () {
      var COOKIE_NAME = "erdangjiade";
      if (jQuery.cookie(COOKIE_NAME)) {
        document.querySelector(".layer").style.display = 'none';
        document.getElementById("globalAd").style.display = 'none';
      } else {
        var erdangjiadeH = window.innerHeight;
        var erdangjiadeW = window.innerWidth;
        document.querySelector(".layer").style.display = 'block';
        var g = document.getElementById("globalAd");
        g.style.top  = (erdangjiadeH / 2 - g.offsetHeight / 2) + 'px';
        g.style.left = (erdangjiadeW / 2 - g.offsetWidth  / 2) + 'px';
        g.style.display = 'block';
        setTimeout(closeGlobalAd, 300000);
        jQuery.cookie(COOKIE_NAME, "erdangjiade", { path: '/', expires: 1 });
      }
    })();
  });

